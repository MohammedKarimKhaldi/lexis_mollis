    font-size: 0.84rem;
    font-weight: 800;
  }

  input {
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: #fffefb;
    color: var(--ink);
    padding: 0.72rem 0.86rem;
  }

  .graph-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin: 0 0 14px;
    padding: 0;
    list-style: none;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .graph-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    flex-shrink: 0;
  }

  #sigma-container {
    height: min(66vh, 620px);
    min-height: 420px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background:
      radial-gradient(circle at 20% 20%, rgba(31, 111, 120, 0.12), transparent 20rem),
