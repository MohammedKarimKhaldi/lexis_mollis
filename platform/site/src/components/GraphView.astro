<section class="graph-shell card">
  <div class="graph-toolbar">
    <label>
      <span>Filtrer un nœud</span>
      <input id="graph-filter" type="search" placeholder="Titre, État, thème…" />
    </label>
    <span id="graph-count" class="muted">Chargement du graphe…</span>
  </div>
  <ul class="graph-legend" aria-label="Légende des types de nœuds">
    <li><span class="dot" style="background:#1f6f78"></span>Document</li>
    <li><span class="dot" style="background:#354a5f"></span>Instrument</li>
    <li><span class="dot" style="background:#7b5d2f"></span>État</li>
    <li><span class="dot" style="background:#594c8f"></span>Organisation</li>
    <li><span class="dot" style="background:#23724d"></span>Thème</li>
  </ul>
  <div id="sigma-container" aria-label="Graphe de connaissances Lexis Mollis"></div>
  <div id="graph-detail" class="graph-detail muted">Clique un nœud pour afficher ses détails.</div>
  <noscript>
    <p class="muted">Le graphe interactif nécessite JavaScript. Export brut : <a href="/data/graph.sigma.json">graph.sigma.json</a>.</p>
  </noscript>
</section>

<script>
  import Graph from "graphology";
  import Sigma from "sigma";

  const container = document.querySelector("#sigma-container");
  const detail = document.querySelector("#graph-detail");
  const count = document.querySelector("#graph-count");
  const filter = document.querySelector("#graph-filter");
  const payload = await fetch("/data/graph.sigma.json").then((response) => response.json());
  const graph = new Graph();
  const colors = {
    Document: "#1f6f78",
    Instrument: "#354a5f",
    State: "#7b5d2f",
    Organization: "#594c8f",
    Topic: "#23724d",
    default: "#8c96a3"
  };

  for (const node of payload.nodes || []) {
    graph.addNode(node.id, {
      label: node.label || node.id,
      x: Number.isFinite(node.x) ? node.x : Math.random(),
      y: Number.isFinite(node.y) ? node.y : Math.random(),
      size: node.size || 4,
      color: colors[node.type] || colors.default,
      type: node.type || "Node",
      document_id: node.document_id || node.id.replace(/^doc:/, "")
    });
  }

  for (const edge of payload.edges || []) {
    if (graph.hasNode(edge.source) && graph.hasNode(edge.target)) {
      graph.mergeEdge(edge.source, edge.target, {
        label: edge.type || "link",
        size: Math.max(1, Number(edge.weight || 1)),
        color: edge.provisional ? "rgba(154, 91, 31, 0.45)" : "rgba(23, 33, 43, 0.22)"
      });
    }
  }

  const renderer = new Sigma(graph, container, {
    renderEdgeLabels: false,
    allowInvalidContainer: true
  });

  count.textContent = `${graph.order} nœuds · ${graph.size} liens`;

  renderer.on("clickNode", ({ node }) => {
    const attrs = graph.getNodeAttributes(node);
    const href = attrs.type === "Document" ? `/document/${encodeURIComponent(attrs.document_id)}/` : null;
    detail.innerHTML = href
      ? `<strong>${attrs.label}</strong><br><span>${attrs.type}</span><br><a class="button secondary" href="${href}">Ouvrir la fiche</a>`
      : `<strong>${attrs.label}</strong><br><span>${attrs.type}</span>`;
  });

  filter.addEventListener("input", () => {
    const q = filter.value.trim().toLowerCase();
    renderer.setSetting("nodeReducer", (node, data) => {
      if (!q) return data;
      const label = String(data.label || "").toLowerCase();
      if (label.includes(q)) return { ...data, color: "#144d57", size: Math.max(data.size, 8) };
      return { ...data, color: "rgba(140,150,163,0.18)", label: "" };
    });
    renderer.refresh();
  });
</script>

